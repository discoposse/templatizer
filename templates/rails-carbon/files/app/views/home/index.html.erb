<% if authenticated? %>
  <div class="carbon-surface border-b border-[#e0e0e0]">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <div class="carbon-card max-w-2xl p-10">
        <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-[#525252]">Dashboard</p>
        <h1 class="mt-4 text-3xl font-semibold tracking-tight text-[#161616]">
          Welcome back<% if Current.user&.first_name.present? %>, <%= Current.user.first_name %><% end %>.
        </h1>
        <p class="mt-4 text-base leading-7 text-[#525252]">
          You are signed in to <strong><%= app_display_name %></strong>. Replace this view with your product home.
        </p>
      </div>
    </div>
  </div>
<% else %>
  <div class="carbon-surface">
    <section class="border-b border-[#e0e0e0] bg-white">
      <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8 lg:py-24">
        <div class="max-w-3xl">
          <h1 class="text-5xl font-semibold tracking-tight text-[#161616] sm:text-6xl">
            __APP_DISPLAY_NAME__
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[#525252]">
            A new Rails application using the Carbon edition from Templatizer — IBM Plex typography, neutral gray surfaces, and accessible contrast defaults.
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <%= link_to "Create account", sign_up_path, class: glyph_button_classes %>
            <%= link_to "Sign in", new_session_path, class: glyph_button_classes(variant: :secondary) %>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e0e0e0]">
      <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
        <div class="grid gap-6 md:grid-cols-3">
          <article class="carbon-card p-6">
            <h2 class="text-lg font-semibold tracking-tight text-[#161616]">Authentication</h2>
            <p class="mt-3 text-sm leading-6 text-[#525252]">Sessions, sign up, password reset, and email confirmation are wired and ready to extend.</p>
          </article>
          <article class="carbon-card p-6">
            <h2 class="text-lg font-semibold tracking-tight text-[#161616]">Tailwind v4</h2>
            <p class="mt-3 text-sm leading-6 text-[#525252]">Theme tokens live in <code class="font-mono text-xs">application.css</code> with Carbon-aligned grays.</p>
          </article>
          <article class="carbon-card p-6">
            <h2 class="text-lg font-semibold tracking-tight text-[#161616]">Hotwire</h2>
            <p class="mt-3 text-sm leading-6 text-[#525252]">Turbo and importmap are enabled by default for a modern stack.</p>
          </article>
        </div>
      </div>
    </section>
  </div>
<% end %>
