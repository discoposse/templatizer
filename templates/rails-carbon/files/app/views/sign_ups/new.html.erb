<% content_for :title, "Sign up" %>

<div class="carbon-surface flex min-h-full flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h1 class="text-center text-3xl font-semibold tracking-tight text-[#161616]">Create account</h1>
    <p class="mt-2 text-center text-sm text-[#525252]">
      Or
      <%= link_to "sign in", new_session_path, class: "carbon-link font-medium" %>
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="carbon-card px-6 py-8 sm:px-8">
      <%= form_with model: @user, url: sign_up_path, local: true, class: "space-y-6" do |form| %>
        <% if @user.errors.any? %>
          <div class="alert alert-error" role="alert">
            <p class="font-medium">Please fix the following:</p>
            <ul class="mt-2 list-disc pl-5 text-sm">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <%= form.label :first_name, "First name", class: "theme-label" %>
            <%= form.text_field :first_name, required: true, autofocus: true, class: "theme-input" %>
          </div>
          <div>
            <%= form.label :last_name, "Last name", class: "theme-label" %>
            <%= form.text_field :last_name, required: true, class: "theme-input" %>
          </div>
        </div>

        <div>
          <%= form.label :email_address, "Email address", class: "theme-label" %>
          <%= form.email_field :email_address, required: true, class: "theme-input", autocomplete: "email" %>
        </div>

        <div>
          <%= form.label :password, "Password", class: "theme-label" %>
          <%= form.password_field :password, required: true, class: "theme-input", autocomplete: "new-password" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm password", class: "theme-label" %>
          <%= form.password_field :password_confirmation, required: true, class: "theme-input", autocomplete: "new-password" %>
        </div>

        <div>
          <%= form.submit "Create account", class: "#{glyph_button_classes} w-full justify-center" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
