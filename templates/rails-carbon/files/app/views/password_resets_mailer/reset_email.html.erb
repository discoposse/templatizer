<div style="max-width:600px;margin:0 auto;padding:24px;font-family:IBM Plex Sans,Helvetica Neue,Arial,sans-serif;color:#161616;">
  <div style="border:1px solid #e0e0e0;background:#f4f4f4;padding:20px;text-align:center;">
    <h1 style="margin:0;font-size:20px;font-weight:600;">Reset your password</h1>
  </div>
  <div style="border:1px solid #e0e0e0;border-top:none;padding:28px;background:#ffffff;">
    <p>Hello,</p>
    <p>We received a request to reset your password. Use the button below to choose a new password.</p>
    <p style="text-align:center;margin:28px 0;">
      <a href="<%= password_reset_edit_url(token: @token) %>" style="display:inline-block;background:#161616;color:#ffffff;padding:12px 24px;text-decoration:none;font-weight:600;font-size:14px;border:1px solid #161616;">Reset password</a>
    </p>
    <p style="font-size:13px;color:#525252;">Or paste this link into your browser:</p>
    <p style="font-size:12px;color:#6f6f6f;word-break:break-all;"><%= password_reset_edit_url(token: @token) %></p>
    <p style="font-size:13px;color:#525252;margin-top:24px;">This link expires in 20 minutes. If you did not request a reset, you can ignore this email.</p>
  </div>
</div>
