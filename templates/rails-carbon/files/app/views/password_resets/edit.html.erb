<% content_for :title, "Set new password" %>

<div class="carbon-surface flex min-h-full flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h1 class="text-center text-3xl font-semibold tracking-tight text-[#161616]">Set new password</h1>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="carbon-card px-6 py-8 sm:px-8">
      <% if @user&.errors&.any? %>
        <div class="alert alert-error mb-6" role="alert">
          <ul class="list-disc pl-5 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with url: password_reset_edit_path(token: params[:token]), method: :patch, local: true, class: "space-y-6" do |form| %>
        <div>
          <%= form.label :password, "New password", class: "theme-label" %>
          <%= form.password_field :password, required: true, autofocus: true, class: "theme-input", autocomplete: "new-password" %>
        </div>
        <div>
          <%= form.label :password_confirmation, "Confirm new password", class: "theme-label" %>
          <%= form.password_field :password_confirmation, required: true, class: "theme-input", autocomplete: "new-password" %>
        </div>
        <div>
          <%= form.submit "Update password", class: "#{glyph_button_classes} w-full justify-center" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
