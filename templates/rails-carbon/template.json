{
  "id": "rails-carbon",
  "name": "Rails Carbon Edition",
  "description": "Rails 8 app with authentication and IBM Carbon Design System styling (IBM Plex, Gray 100 palette, glyph navigation). UI is generated from file templates via the Templatizer render engine.",
  "version": "1.0.0",
  "author": "Templatizer Team",
  "framework": "rails",
  "framework_version": "8.0",
  "theme": {
    "design_system": "carbon-11-aligned",
    "engine": "scripts/engine/render-tree.sh",
    "source_files": "templates/rails-carbon/files"
  },
  "dependencies": {
    "ruby": ">= 3.1.0",
    "rails": ">= 8.0.0",
    "postgresql": ">= 14.0",
    "node": ">= 18.0"
  },
  "features": [
    "authentication",
    "tailwind-css-v4",
    "hotwire",
    "postgresql",
    "carbon-ui",
    "ibm-plex",
    "file-driven-theme"
  ],
  "files": {
    "create_script": "create_rails_app.sh",
    "shared_core": "../.shared/create_rails_app.sh"
  },
  "test_commands": [
    "rails db:migrate",
    "rails tailwindcss:build",
    "rails server -p 3000"
  ],
  "validation_checks": [
    "database_connection",
    "migration_success",
    "tailwind_compilation",
    "authentication_models",
    "routes_configuration"
  ]
}
